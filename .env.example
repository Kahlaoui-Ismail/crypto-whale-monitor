ETHERSCAN_API_KEY=your_etherscan_api_key_here
ETH_THRESHOLD=100
SOL_THRESHOLD=10000
POLL_INTERVAL_SECONDS=30
ALLOWED_ORIGINS=http://localhost:3000

# Frontend build-time variable (prefix with VITE_).
# Leave empty for local Docker (nginx proxy handles /api/*).
# Set to your backend URL when deploying to Render / any external host.
VITE_API_BASE=
